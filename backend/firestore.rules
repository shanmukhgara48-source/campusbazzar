rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Only used for message sub-collection — chat doc is guaranteed to exist there.
    function isChatParticipant(chatId) {
      return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;

      match /savedItems/{listingId} {
        allow read, write: if isAuth() && isOwner(uid);
      }
    }

    // ── Listings ───────────────────────────────────────────────────────────────
    match /listings/{listingId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.sellerId == request.auth.uid;

      // Seller can update any field on their own listing.
      // Any authenticated user can flip only 'status' to 'sold' (handlePurchase / runTransaction).
      // Any authenticated user can set the deal fields when an offer is accepted
      //   (acceptOffer batch runs under the seller's auth, but the runTransaction in
      //    handlePurchase runs under the buyer's auth and only touches 'status').
      allow update: if isAuth() && (
        resource.data.sellerId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        || (
          request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['status', 'finalPrice', 'acceptedOfferId', 'acceptedBuyerId'])
          && request.resource.data.status in ['sold', 'reserved']
        )
      );

      // Seller can delete manually.
      // Any authenticated user can delete a non-sold listing — this is the
      // quantity==1 path inside handlePurchase's runTransaction (buyer deletes
      // the last unit atomically). The transaction reads the doc first and only
      // deletes it when status != 'sold', so a race can never double-delete.
      allow delete: if isAuth() && (
        resource.data.sellerId == request.auth.uid ||
        resource.data.status   != 'sold'
      );
    }

    // ── Offers ─────────────────────────────────────────────────────────────────
    match /offers/{offerId} {
      allow read: if isAuth() && (
        resource.data.buyerId  == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAuth() && resource.data.sellerId == request.auth.uid;
      allow delete: if false;
    }

    // ── Transactions ───────────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuth() && (
        resource.data.buyerId  == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
      // Buyer creates when they do Buy Now (MeetupScreen).
      // Seller creates when they accept an offer (acceptOffer in offerService).
      allow create: if isAuth() && (
        request.resource.data.buyerId  == request.auth.uid ||
        request.resource.data.sellerId == request.auth.uid
      );
      allow update: if isAuth() && (
        resource.data.buyerId  == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
      allow delete: if false;
    }

    // ── Notifications ──────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Chats ──────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      // resource == null when the doc doesn't exist yet — getOrCreateChat reads
      // first to check existence, so that read must succeed before the create.
      allow read: if isAuth() && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuth() && isChatParticipant(chatId);

        // Normal messages: senderId must be the caller.
        // System messages (type == 'system'): any participant can post.
        allow create: if isAuth()
          && isChatParticipant(chatId)
          && (
            request.resource.data.senderId == request.auth.uid
            || request.resource.data.type == 'system'
          );

        // Participants may update ONLY the 'status' field on offer messages
        // (seller accepts/rejects → flips status to 'accepted'/'rejected').
        allow update: if isAuth()
          && isChatParticipant(chatId)
          && resource.data.type == 'offer'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status in ['accepted', 'rejected'];

        allow delete: if false;
      }
    }

    // ── Blocked users (per-user private subcollection) ─────────────────────────
    match /users/{uid}/blockedUsers/{targetUid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // ── Reports (user-submitted content reports for admin review) ──────────────
    match /reports/{reportId} {
      allow create: if isAuth() && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ── Reviews ────────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read:          if isAuth();
      allow create:        if isAuth() && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Waitlist (landing page — no auth required) ─────────────────────────────
    // Public can create (submit email from landing page).
    // No reads, updates, or deletes allowed publicly — admin access only.
    match /waitlist/{docId} {
      allow create, update: if true
        && request.resource.data.keys().hasAll(['email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0;
      allow read, delete: if false;
    }
  }
}
